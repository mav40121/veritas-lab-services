#!/bin/bash
# VeritaAssure Commit Message Hook
# Enforces the mandatory response template on every substantive commit.
# To bypass in a genuine emergency: git commit --no-verify
# (document the reason in the commit message)

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip enforcement for automated/chore commits
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
if echo "$FIRST_LINE" | grep -qE "^(chore|ci|bump|merge|revert|wip):"; then
  exit 0
fi

MISSING=""

# Require TASK:
if ! echo "$COMMIT_MSG" | grep -qiE "^TASK:"; then
  MISSING="$MISSING TASK:"
fi

# Require PLAN:
if ! echo "$COMMIT_MSG" | grep -qiE "^PLAN:"; then
  MISSING="$MISSING PLAN:"
fi

# Require Self-check:
if ! echo "$COMMIT_MSG" | grep -qiE "^Self-check:"; then
  MISSING="$MISSING Self-check:"
fi

if [ -n "$MISSING" ]; then
  echo ""
  echo "COMMIT BLOCKED: Missing required sections:$MISSING"
  echo ""
  echo "Every substantive commit must include the full response template."
  echo "Add these sections to your commit message:"
  echo ""
  echo "  TASK: [restate what this commit does]"
  echo "  ASSUMPTIONS: [list assumptions]"
  echo "  PLAN:"
  echo "    1. [step]"
  echo "    2. [step]"
  echo "  Self-check:"
  echo "    - Potential error 1: [what could go wrong]"
  echo "    - Potential error 2: [what could go wrong]"
  echo "    - Potential error 3: [what could go wrong]"
  echo "    - Verified: [what you checked]"
  echo ""
  echo "To bypass in a genuine emergency: git commit --no-verify"
  echo "(Document why in the commit message.)"
  exit 1
fi

exit 0
